  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "preserve_recent_tokens": 12000,
    "reserved": 20000
  },
  "mcp": {
    "notion-dev": {
      "type": "remote",
      "url": "https://mcp-dev.notion.com/mcp",
      "oauth": {
        "callbackPort": 50001
      },
      "timeout": 30000
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "sudo *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",
      "git push": "ask",
      "git push *": "ask"
    },
    "get_goal": "allow",
    "get_goal_history": "allow",
    "create_goal": "deny",
    "set_goal": "deny",
    "update_goal_objective": "deny",
    "update_goal": "deny",
    "update_goal_status": "deny",
    "clear_goal": "deny",
    "advisor": "deny",
    "doom_loop": "ask"
