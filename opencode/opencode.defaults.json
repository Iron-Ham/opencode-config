{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "default_agent": "build",
  "share": "disabled",
  "autoupdate": "notify",
  "lsp": true,
  "disabled_providers": [
    "amazon-bedrock",
    "opencode"
  ],
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": false,
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "gpt-5.6-luna": {
          "cost": {
            "input": 1,
            "output": 6,
            "cache_read": 0.1,
            "cache_write": 1.25
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.6-sol": {
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "cache_write": 6.25
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.6-terra": {
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 3.125
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        }
      }
    },
    "baseten": {
      "env": [
        "BASETEN_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "name": "Baseten",
      "options": {
        "baseURL": "https://inference.baseten.co/v1"
      },
      "models": {
        "zai-org/GLM-5.2": {
          "limit": {
            "context": 202720,
            "input": 202720,
            "output": 128000
          }
        }
      },
      "whitelist": [
        "zai-org/GLM-5.2",
        "moonshotai/Kimi-K2.7-Code",
        "deepseek-ai/DeepSeek-V4-Pro"
      ]
    },
    "fireworks-ai": {
      "env": [
        "FIREWORKS_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fireworks AI",
      "options": {
        "baseURL": "https://api.fireworks.ai/inference/v1/"
      },
      "whitelist": [
        "accounts/fireworks/models/glm-5p2",
        "accounts/fireworks/routers/glm-5p2-fast",
        "accounts/fireworks/models/kimi-k2p7-code",
        "accounts/fireworks/routers/kimi-k2p7-code-fast"
      ]
    }
  },
  "agent": {
    "build": {
      "permission": {
        "advisor": "deny",
        "get_goal": "allow",
        "get_goal_history": "allow",
        "create_goal": "allow",
        "set_goal": "allow",
        "update_goal_objective": "allow",
        "update_goal": "allow",
        "update_goal_status": "allow",
        "clear_goal": "allow",
        "record_goal_progress": "allow",
        "record_goal_failure": "allow",
        "task": {
          "*": "deny",
          "accessibility_auditor": "allow",
          "code_reviewer": "allow",
          "database_optimizer": "allow",
          "evidence_analyst": "allow",
          "explore": "allow",
          "general": "allow",
          "security_engineer": "allow",
          "software_architect": "allow"
        }
      }
    },
    "plan": {
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "*": "ask",
        "question": "allow",
        "read": {
          "*": "allow",
          ".env": "deny",
          ".env.*": "deny",
          "*.env": "deny",
          "*.env.*": "deny",
          ".env.example": "allow",
          "*.env.example": "allow"
        },
        "external_directory": {
          "~/**": "allow",
          "~/.aws/**": "deny",
          "~/.azure/**": "deny",
          "~/.cargo/**": "deny",
          "~/.config/**": "allow",
          "~/.docker/**": "deny",
          "~/.gem/**": "deny",
          "~/.git-credentials": "deny",
          "~/.gnupg/**": "deny",
          "~/.kube/**": "deny",
          "~/.local/share/**": "deny",
          "~/.netrc": "deny",
          "~/.npmrc": "deny",
          "~/.oci/**": "deny",
          "~/.pypirc": "deny",
          "~/.ssh/**": "deny",
          "~/.terraform.d/**": "deny",
          "~/Library/**": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "todowrite": "allow",
        "advisor": "deny",
        "create_goal": "deny",
        "set_goal": "deny",
        "update_goal_objective": "deny",
        "update_goal": "deny",
        "update_goal_status": "deny",
        "clear_goal": "deny",
        "record_goal_progress": "deny",
        "record_goal_failure": "deny",
        "task": {
          "*": "deny",
          "accessibility_auditor": "allow",
          "code_reviewer": "allow",
          "explore": "allow",
          "security_engineer": "allow",
          "software_architect": "allow"
        }
      }
    },
    "general": {
      "permission": {
        "*": "deny",
        "question": "deny",
        "read": {
          "*": "allow",
          ".env": "deny",
          ".env.*": "deny",
          "*.env": "deny",
          "*.env.*": "deny",
          ".env.example": "allow",
          "*.env.example": "allow"
        },
        "external_directory": {
          "~/**": "allow",
          "~/.aws/**": "deny",
          "~/.azure/**": "deny",
          "~/.cargo/**": "deny",
          "~/.config/**": "allow",
          "~/.docker/**": "deny",
          "~/.gem/**": "deny",
          "~/.git-credentials": "deny",
          "~/.gnupg/**": "deny",
          "~/.kube/**": "deny",
          "~/.local/share/**": "deny",
          "~/.netrc": "deny",
          "~/.npmrc": "deny",
          "~/.oci/**": "deny",
          "~/.pypirc": "deny",
          "~/.ssh/**": "deny",
          "~/.terraform.d/**": "deny",
          "~/Library/**": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "sudo *": "deny",
          "git reset --hard": "deny",
          "git reset --hard *": "deny",
          "git clean *": "deny",
          "git push": "deny",
          "git push *": "deny"
        },
        "task": "deny",
        "todowrite": "deny",
        "advisor": "deny",
        "create_goal": "deny",
        "set_goal": "deny",
        "update_goal_objective": "deny",
        "update_goal": "deny",
        "update_goal_status": "deny",
        "clear_goal": "deny"
      }
    },
    "explore": {
      "steps": 100,
      "permission": {
        "*": "deny",
        "question": "deny",
        "read": {
          "*": "allow",
          ".env": "deny",
          ".env.*": "deny",
          "*.env": "deny",
          "*.env.*": "deny",
          ".env.example": "allow",
          "*.env.example": "allow"
        },
        "external_directory": {
          "~/**": "allow",
          "~/.aws/**": "deny",
          "~/.azure/**": "deny",
          "~/.cargo/**": "deny",
          "~/.config/**": "allow",
          "~/.docker/**": "deny",
          "~/.gem/**": "deny",
          "~/.git-credentials": "deny",
          "~/.gnupg/**": "deny",
          "~/.kube/**": "deny",
          "~/.local/share/**": "deny",
          "~/.netrc": "deny",
          "~/.npmrc": "deny",
          "~/.oci/**": "deny",
          "~/.pypirc": "deny",
          "~/.ssh/**": "deny",
          "~/.terraform.d/**": "deny",
          "~/Library/**": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "todowrite": "deny",
        "advisor": "deny"
      }
    },
    "accessibility_auditor": {
      "steps": 100
    },
    "code_reviewer": {
      "steps": 100
    },
    "database_optimizer": {
      "steps": 100
    },
    "evidence_analyst": {
      "steps": 100
    },
    "glm_worker": {
      "model": "baseten/zai-org/GLM-5.2",
      "steps": 100
    },
    "kimi_reader": {
      "model": "baseten/moonshotai/Kimi-K2.7-Code",
      "steps": 100
    },
    "security_engineer": {
      "steps": 100
    },
    "software_architect": {
      "steps": 100
    },
    "advisor_reviewer": {
      "model": "anthropic/claude-opus-4-8",
      "steps": 60
    },
    "ultra": {
      "description": "Unattended execution policy for /ultra; direct use omits the command template.",
      "hidden": false,
      "mode": "primary",
      "permission": {
        "advisor": "deny",
        "question": "deny",
        "plan_enter": "deny",
        "get_goal": "allow",
        "get_goal_history": "allow",
        "create_goal": "allow",
        "set_goal": "allow",
        "update_goal_objective": "allow",
        "update_goal": "allow",
        "update_goal_status": "allow",
        "clear_goal": "allow",
        "record_goal_progress": "allow",
        "record_goal_failure": "allow",
        "task": {
          "*": "deny",
          "accessibility_auditor": "allow",
          "code_reviewer": "allow",
          "database_optimizer": "allow",
          "evidence_analyst": "allow",
          "explore": "allow",
          "general": "allow",
          "security_engineer": "allow",
          "software_architect": "allow"
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "preserve_recent_tokens": 12000,
    "reserved": 20000
  },
  "mcp": {
    "notion-dev": {
      "type": "remote",
      "url": "https://mcp-dev.notion.com/mcp",
      "oauth": {
        "callbackPort": 50001
      },
      "timeout": 30000
    }
  },
  "permission": {
    "external_directory": {
      "~/**": "allow",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
      "~/.cargo/**": "deny",
      "~/.config/**": "allow",
      "~/.docker/**": "deny",
      "~/.gem/**": "deny",
      "~/.git-credentials": "deny",
      "~/.gnupg/**": "deny",
      "~/.kube/**": "deny",
      "~/.local/share/**": "deny",
      "~/.netrc": "deny",
      "~/.npmrc": "deny",
      "~/.oci/**": "deny",
      "~/.pypirc": "deny",
      "~/.ssh/**": "deny",
      "~/.terraform.d/**": "deny",
      "~/Library/**": "deny"
    },
    "read": {
      "*": "allow",
      ".env": "deny",
      ".env.*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow",
      "*.env.example": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "sudo *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git clean *": "ask",
      "git push": "ask",
      "git push *": "ask"
    },
    "get_goal": "allow",
    "get_goal_history": "allow",
    "create_goal": "deny",
    "set_goal": "deny",
    "update_goal_objective": "deny",
    "update_goal": "deny",
    "update_goal_status": "deny",
    "clear_goal": "deny",
    "record_goal_progress": "deny",
    "record_goal_failure": "deny",
    "advisor": "deny",
    "doom_loop": "ask"
  },
  "plugin": [
    [
      "./plugins/goal-mode.js",
      {
        "auto_continue": true,
        "defer_while_tasks_active": true,
        "max_auto_turns": 9007199254740991,
        "max_prompt_failures": 3,
        "max_repeated_failures": 3,
        "max_repeated_tool_calls": 3,
        "retry_base_seconds": 1,
        "retry_max_seconds": 60,
        "no_progress_token_threshold": 50,
        "max_no_progress_turns": 3,
        "restricted_agents": [
          "plan"
        ],
        "allow_goal_execution_from_plan": false
      }
    ],
    [
      "./plugins/compaction-observability.js",
      {
        "model_strategy": "active-session"
      }
    ],
    [
      "./plugins/delegation-guard.js",
      {
        "max_concurrent": 4,
        "max_total": 8,
        "isolated_review_agents": [
          "accessibility_auditor",
          "code_reviewer",
          "database_optimizer",
          "evidence_analyst",
          "security_engineer",
          "software_architect"
        ]
      }
    ],
    "./plugins/goal-workflow-guard.js"
  ]
}
