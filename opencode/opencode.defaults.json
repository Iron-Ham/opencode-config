          "~/.pypirc": "deny",
          "~/.ssh/**": "deny",
          "~/.terraform.d/**": "deny",
          "~/Library/**": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "text_read": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "edit": "allow",
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "sudo *": "deny",
          "git reset --hard": "deny",
          "git reset --hard *": "deny",
          "git clean *": "deny",
          "git push": "deny",
          "git push *": "deny"
        },
        "task": "deny",
        "todowrite": "deny",
        "advisor": "deny"
      }
    },
    "explore": {
      "steps": 100,
      "permission": {
        "*": "deny",
        "question": "deny",
        "read": {
          "*": "allow",
          ".env": "deny",
          ".env.*": "deny",
          "*.env": "deny",
          "*.env.*": "deny",
          ".env.example": "allow",
