  "agent": {
    "build": {
      "model": "openai/gpt-5.6-terra-xhigh-pinned",
      "permission": {
        "advisor": "deny",
        "create_goal": "allow",
        "set_goal": "allow",
        "update_goal_objective": "allow",
        "update_goal": "allow",
        "update_goal_status": "allow",
        "clear_goal": "allow",
        "task": {
          "*": "deny",
          "accessibility_auditor": "allow",
          "code_reviewer": "allow",
          "database_optimizer": "allow",
          "evidence_analyst": "allow",
          "explore": "allow",
          "general": "allow",
