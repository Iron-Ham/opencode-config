{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "default_agent": "build",
  "share": "disabled",
  "autoupdate": "notify",
  "lsp": true,
  "tool_output": {
    "max_lines": 300,
    "max_bytes": 16384
  },
  "disabled_providers": [
    "amazon-bedrock",
    "opencode"
  ],
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": false,
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "gpt-5.6-luna": {
          "cost": {
            "input": 1,
            "output": 6,
            "cache_read": 0.1,
            "cache_write": 1.25
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.6-sol": {
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "cache_write": 6.25
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.6-terra": {
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 3.125
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        }
      }
    },
    "baseten": {
      "env": [
        "BASETEN_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "name": "Baseten",
      "options": {
        "baseURL": "https://inference.baseten.co/v1"
      },
      "whitelist": [
        "deepseek-ai/DeepSeek-V4-Pro"
      ]
    }
  },
  "agent": {
    "build": {
      "permission": {
        "advisor": "deny",
        "task": {
          "*": "deny",
          "accessibility_auditor": "allow",
          "code_reviewer": "allow",
          "database_optimizer": "allow",
          "evidence_analyst": "allow",
          "explore": "allow",
          "general": "allow",
          "security_engineer": "allow",
          "software_architect": "allow"
        }
      }
    },
    "plan": {
      "model": "openai/gpt-5.6-terra",
      "permission": {
        "*": "ask",
        "question": "allow",
        "read": {
          "*": "allow",
          ".env": "deny",
          ".env.*": "deny",
          "*.env": "deny",
          "*.env.*": "deny",
          ".env.example": "allow",
          "*.env.example": "allow"
        },
        "external_directory": {
          "~/**": "allow",
          "~/.aws/**": "deny",
          "~/.azure/**": "deny",
          "~/.cargo/**": "deny",
          "~/.config/**": "allow",
          "~/.docker/**": "deny",
          "~/.gem/**": "deny",
          "~/.git-credentials": "deny",
          "~/.gnupg/**": "deny",
          "~/.kube/**": "deny",
          "~/.local/share/**": "deny",
          "~/.netrc": "deny",
          "~/.npmrc": "deny",
          "~/.oci/**": "deny",
          "~/.pypirc": "deny",
          "~/.ssh/**": "deny",
          "~/.terraform.d/**": "deny",
          "~/Library/**": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "text_read": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "ask",
        "todowrite": "allow",
        "advisor": "deny",
        "task": {
          "*": "deny",
          "accessibility_auditor": "allow",
          "code_reviewer": "allow",
          "explore": "allow",
          "security_engineer": "allow",
          "software_architect": "allow"
        }
      }
    },
