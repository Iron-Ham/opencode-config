{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra-xhigh-pinned",
  "default_agent": "build",
  "share": "disabled",
  "autoupdate": "notify",
  "lsp": true,
  "disabled_providers": [
    "amazon-bedrock",
    "opencode"
  ],
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": false,
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "gpt-5.6-luna": {
          "cost": {
            "input": 1,
            "output": 6,
            "cache_read": 0.1,
            "cache_write": 1.25
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.6-sol": {
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "cache_write": 6.25
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.6-terra": {
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 3.125
          },
          "limit": {
            "context": 1050000,
            "input": 922000,
            "output": 128000
          }
        },
        "gpt-5.6-luna-xhigh-pinned": {
          "id": "gpt-5.6-luna",
          "name": "GPT-5.6 Luna xhigh (pinned)",
          "limit": {
            "context": 1050000,
            "input": 256000,
            "output": 128000
          },
          "options": {
            "reasoningEffort": "xhigh",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ]
          },
          "variants": {
            "none": {
              "disabled": true
            },
            "low": {
              "disabled": true
            },
            "medium": {
              "disabled": true
            },
            "high": {
              "disabled": true
            },
            "xhigh": {
