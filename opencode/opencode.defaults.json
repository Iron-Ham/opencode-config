    },
    "database_optimizer": {
      "steps": 100
    },
    "evidence_analyst": {
      "steps": 100
    },
    "security_engineer": {
      "steps": 100
    },
    "software_architect": {
      "steps": 100
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "preserve_recent_tokens": 12000,
    "reserved": 20000
  },
  "mcp": {
    "notion-dev": {
      "type": "remote",
      "url": "https://mcp-dev.notion.com/mcp",
      "oauth": {
        "callbackPort": 50001
      },
      "timeout": 30000
    }
  },
  "permission": {
    "external_directory": {
      "~/**": "allow",
      "~/.aws/**": "deny",
      "~/.azure/**": "deny",
