          "~/.local/share/**": "deny",
          "~/.netrc": "deny",
          "~/.npmrc": "deny",
          "~/.oci/**": "deny",
          "~/.pypirc": "deny",
          "~/.ssh/**": "deny",
          "~/.terraform.d/**": "deny",
          "~/Library/**": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "text_read": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "todowrite": "deny",
        "advisor": "deny"
      }
    },
    "accessibility_auditor": {
      "steps": 100
    },
    "code_reviewer": {
